---
const quickLinks = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Services', href: '/#services' },
  { name: 'Reviews', href: '/reviews' },
  { name: 'Get a Quote', href: '/get-a-quote' },
  { name: 'FAQ', href: '/faq' },
  { name: 'Contact', href: '/contact' },
  { name: 'Careers', href: '/careers' },
];

const residentialServices = [
  { name: 'Site Preparation', href: '/services/site-preparation' },
  { name: 'Excavation', href: '/services/excavation' },
  { name: 'Land Clearing', href: '/services/land-clearing' },
  { name: 'Drainage & Erosion Control', href: '/services/drainage' },
  { name: 'Driveway & Road Building', href: '/services/driveway' },
];

const commercialServices = [
  { name: 'Grading & Earthwork', href: '/services/grading' },
  { name: 'Demolition', href: '/services/demolition' },
  { name: 'Utility Trenching', href: '/services/trenching' },
  { name: 'Site Preparation', href: '/services/site-preparation' },
  { name: 'Land Clearing', href: '/services/land-clearing' },
];
---

<footer class="bg-[#1a1a1a] text-white pt-16 pb-8">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8 mb-12">
      <!-- Company Info -->
      <div>
        <img 
          src="/images/liteworks-logo.png" 
          alt="Liteworks Co." 
          class="h-10 w-auto mb-4"
        />
        <p class="text-[#c4d931] font-[Rajdhani] text-lg font-semibold mb-4">
          Heavy Work. Light Touch.
        </p>
        <p class="text-gray-400 text-sm">
          Greater Cincinnati's trusted excavation and sitework experts. We bring industrial power with a personal approach.
        </p>
        
        <!-- Social Links -->
        <div class="flex space-x-4 mt-6">
          {/* TODO: create facebook.com/liteworksco */}
          <a href="#" class="text-gray-400 hover:text-[#c4d931] transition" aria-label="Facebook">
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          {/* TODO: create instagram.com/liteworksco */}
          <a href="#" class="text-gray-400 hover:text-[#c4d931] transition" aria-label="Instagram">
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"/>
            </svg>
          </a>
          {/* TODO: create linkedin.com/company/liteworks-co */}
          <a href="#" class="text-gray-400 hover:text-[#c4d931] transition" aria-label="LinkedIn">
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="#" class="text-gray-400 hover:text-[#c4d931] transition" aria-label="YouTube">
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-[Rajdhani] font-bold mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-[#c4d931] transition text-sm">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Residential Services -->
      <div>
        <h3 class="text-lg font-[Rajdhani] font-bold mb-4">Residential</h3>
        <ul class="space-y-2">
          {residentialServices.map((service) => (
            <li>
              <a href={service.href} class="text-gray-400 hover:text-[#c4d931] transition text-sm">
                {service.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Commercial Services -->
      <div>
        <h3 class="text-lg font-[Rajdhani] font-bold mb-4">Commercial</h3>
        <ul class="space-y-2">
          {commercialServices.map((service) => (
            <li>
              <a href={service.href} class="text-gray-400 hover:text-[#c4d931] transition text-sm">
                {service.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-lg font-[Rajdhani] font-bold mb-4">Contact Us</h3>
        <div class="space-y-3 text-sm text-gray-400">
          <p>
            <span class="block text-white font-medium">Address</span>
            1481 SR 28, Suite 901<br />
            Loveland, OH 45140
          </p>
          <p>
            <span class="block text-white font-medium">Phone</span>
            <a href="tel:5139279675" class="hover:text-[#c4d931] transition">(513) 927-9675</a>
          </p>
          <p>
            <span class="block text-white font-medium">Email</span>
            <a href="mailto:team@liteworksco.com" class="hover:text-[#c4d931] transition">team@liteworksco.com</a>
          </p>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-gray-800 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <p class="text-gray-400 text-sm">
          © 2026 Liteworks Co. All rights reserved.
        </p>
        <p class="text-gray-500 text-sm">
          Serving Greater Cincinnati, Northern Kentucky & Southeast Indiana
        </p>
      </div>
      <div class="flex justify-center space-x-6 mt-4">
        <a href="/privacy" class="text-gray-600 hover:text-gray-400 text-xs transition">Privacy Policy</a>
        <a href="/terms" class="text-gray-600 hover:text-gray-400 text-xs transition">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
