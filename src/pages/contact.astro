---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer.astro';
import { Phone, Mail, MapPin, Clock } from 'lucide-react';
---

<Layout 
  title="Contact Us | Liteworks Co. | Cincinnati Excavation & Sitework"
  description="Contact Liteworks Co. for excavation, land clearing, and sitework services in Greater Cincinnati. Call, email, or send us a message."
>
  <Header client:load />
  
  <main class="pt-20">
    <!-- Hero Section -->
    <section class="py-16 bg-[#1a1a1a]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-[Rajdhani] font-bold text-white mb-4">
          Contact <span class="text-[#c4d931]">Us</span>
        </h1>
        <p class="text-xl text-gray-300 max-w-2xl mx-auto">
          We'd love to hear from you. Reach out anytime.
        </p>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12">
          <!-- Contact Info -->
          <div>
            <h2 class="text-3xl font-[Rajdhani] font-bold text-[#1a1a1a] mb-8">
              Get in Touch
            </h2>
            
            <div class="space-y-8">
              <div class="flex items-start gap-5">
                <div class="w-14 h-14 rounded-full bg-[#c4d931] flex items-center justify-center flex-shrink-0">
                  <Phone className="w-6 h-6 text-[#1a1a1a]" />
                </div>
                <div>
                  <h3 class="text-xl font-[Rajdhani] font-bold text-[#1a1a1a] mb-1">Phone</h3>
                  <a href="tel:5139279675" class="text-lg text-gray-600 hover:text-[#c4d931] transition">
                    (513) 927-9675
                  </a>
                  <p class="text-gray-500 text-sm mt-1">Call or text anytime</p>
                </div>
              </div>
              
              <div class="flex items-start gap-5">
                <div class="w-14 h-14 rounded-full bg-[#c4d931] flex items-center justify-center flex-shrink-0">
                  <Mail className="w-6 h-6 text-[#1a1a1a]" />
                </div>
                <div>
                  <h3 class="text-xl font-[Rajdhani] font-bold text-[#1a1a1a] mb-1">Email</h3>
                  <a href="mailto:team@liteworksco.com" class="text-lg text-gray-600 hover:text-[#c4d931] transition">
                    team@liteworksco.com
                  </a>
                  <p class="text-gray-500 text-sm mt-1">We typically respond within 24 hours</p>
                </div>
              </div>
              
              <div class="flex items-start gap-5">
                <div class="w-14 h-14 rounded-full bg-[#c4d931] flex items-center justify-center flex-shrink-0">
                  <MapPin className="w-6 h-6 text-[#1a1a1a]" />
                </div>
                <div>
                  <h3 class="text-xl font-[Rajdhani] font-bold text-[#1a1a1a] mb-1">Office</h3>
                  <p class="text-lg text-gray-600">
                    1481 SR 28, Suite 901<br />
                    Loveland, OH 45140
                  </p>
                </div>
              </div>
              
              <div class="flex items-start gap-5">
                <div class="w-14 h-14 rounded-full bg-[#c4d931] flex items-center justify-center flex-shrink-0">
                  <Clock className="w-6 h-6 text-[#1a1a1a]" />
                </div>
                <div>
                  <h3 class="text-xl font-[Rajdhani] font-bold text-[#1a1a1a] mb-1">Hours</h3>
                  <p class="text-lg text-gray-600">
                    Monday - Friday: 7am - 6pm<br />
                    Saturday: 8am - 4pm<br />
                    Sunday: Closed
                  </p>
                </div>
              </div>
            </div>
            
            <!-- Service Area -->
            <div class="mt-12 p-6 bg-[#f5f5f0] rounded-lg">
              <h3 class="text-xl font-[Rajdhani] font-bold text-[#1a1a1a] mb-4">Service Area</h3>
              <p class="text-gray-600 mb-4">
                We proudly serve Greater Cincinnati and the surrounding areas:
              </p>
              <div class="grid grid-cols-2 gap-2 text-gray-600">
                <div>
                  <strong class="text-[#1a1a1a]">Ohio</strong>
                  <ul class="mt-1 space-y-1 text-sm">
                    <li>Hamilton County</li>
                    <li>Butler County</li>
                    <li>Warren County</li>
                    <li>Clermont County</li>
                  </ul>
                </div>
                <div>
                  <strong class="text-[#1a1a1a]">Kentucky & Indiana</strong>
                  <ul class="mt-1 space-y-1 text-sm">
                    <li>Boone County, KY</li>
                    <li>Kenton County, KY</li>
                    <li>Campbell County, KY</li>
                    <li>Southeast Indiana</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Contact Form -->
          <div>
            <div class="bg-[#f5f5f0] rounded-lg p-8">
              <h2 class="text-2xl font-[Rajdhani] font-bold text-[#1a1a1a] mb-6">
                Send Us a Message
              </h2>
              
              <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-6">
                <div class="grid md:grid-cols-2 gap-6">
                  <!-- Name -->
                  <div>
                    <label for="name" class="block text-sm font-medium text-gray-700 mb-2">
                      Your Name *
                    </label>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      required
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#c4d931] focus:border-[#c4d931] outline-none transition bg-white"
                      placeholder="John Smith"
                    />
                  </div>
                  
                  <!-- Email -->
                  <div>
                    <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
                      Email Address *
                    </label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#c4d931] focus:border-[#c4d931] outline-none transition bg-white"
                      placeholder="john@example.com"
                    />
                  </div>
                </div>
                
                <!-- Phone -->
                <div>
                  <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
                    Phone Number
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#c4d931] focus:border-[#c4d931] outline-none transition bg-white"
                    placeholder="(555) 123-4567"
                  />
                </div>
                
                <!-- Subject -->
                <div>
                  <label for="subject" class="block text-sm font-medium text-gray-700 mb-2">
                    Subject *
                  </label>
                  <input
                    type="text"
                    id="subject"
                    name="subject"
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#c4d931] focus:border-[#c4d931] outline-none transition bg-white"
                    placeholder="How can we help?"
                  />
                </div>
                
                <!-- Message -->
                <div>
                  <label for="message" class="block text-sm font-medium text-gray-700 mb-2">
                    Message *
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    required
                    rows="5"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#c4d931] focus:border-[#c4d931] outline-none transition resize-none bg-white"
                    placeholder="Tell us more..."
                  ></textarea>
                </div>
                
                <!-- Submit Button -->
                <div>
                  <button
                    type="submit"
                    class="w-full bg-[#c4d931] text-[#1a1a1a] px-8 py-4 rounded-lg font-[Rajdhani] font-bold text-lg hover:bg-[#b5ca2d] transition"
                  >
                    Send Message
                  </button>
                </div>
              </form>
            </div>
            
            <!-- Quick Quote CTA -->
            <div class="mt-8 p-6 bg-[#1a1a1a] rounded-lg text-center">
              <h3 class="text-xl font-[Rajdhani] font-bold text-white mb-3">
                Need a Quote?
              </h3>
              <p class="text-gray-400 mb-4">
                For project estimates, use our dedicated quote form.
              </p>
              <a href="/get-a-quote" class="btn-primary inline-block">
                Request a Quote
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
