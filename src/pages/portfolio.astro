---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer.astro';
import { Star, MapPin, ArrowRight, Phone } from 'lucide-react';

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Our Work | Liteworks Co.",
  "description": "Before and after project gallery showcasing excavation, land clearing, drainage, and driveway work across Greater Cincinnati.",
  "provider": {
    "@type": "HomeAndConstructionBusiness",
    "name": "Liteworks Co.",
    "telephone": "+1-513-927-9675"
  }
};

const projects = [
  {
    title: "Foundation Excavation",
    location: "Anderson Township, OH",
    category: "Excavation",
    description: "Full basement excavation for new home construction on a tight residential lot with limited access. Clean vertical walls, level bottom, ready for the foundation crew in under two days.",
    before: "/images/portfolio/excavation-before-1.png",
    after: "/images/portfolio/excavation-after-1.png",
    stats: [
      { label: "Duration", value: "2 Days" },
      { label: "Depth", value: "9 ft" },
      { label: "Type", value: "Basement" }
    ]
  },
  {
    title: "French Drain & Regrading",
    location: "West Chester, OH",
    category: "Drainage",
    description: "Homeowner had standing water against the foundation after every rain. We installed a French drain system along the foundation and regraded the entire backyard to slope away from the house.",
    before: "/images/portfolio/drainage-before-1.png",
    after: "/images/portfolio/drainage-after-1.png",
    stats: [
      { label: "Duration", value: "1.5 Days" },
      { label: "Drain Length", value: "85 ft" },
      { label: "Type", value: "French Drain" }
    ]
  },
  {
    title: "Residential Land Clearing",
    location: "Milford, OH",
    category: "Land Clearing",
    description: "Half-acre wooded lot completely overgrown with honeysuckle and dense brush. Forestry mulched the entire parcel, preserved select mature trees, and left it build-ready for the homeowner's contractor.",
    before: "/images/portfolio/clearing-before-1.png",
    after: "/images/portfolio/clearing-after-1.png",
    stats: [
      { label: "Duration", value: "1 Day" },
      { label: "Area", value: "0.5 Acres" },
      { label: "Type", value: "Forestry Mulching" }
    ]
  },
  {
    title: "Concrete Driveway Replacement",
    location: "Lebanon, OH",
    category: "Driveways",
    description: "Broke out and hauled away a badly cracked, heaving concrete driveway. Regraded the base, compacted the subgrade, and poured a new concrete driveway with proper expansion joints and clean edges.",
    before: "/images/portfolio/driveway-before-1.png",
    after: "/images/portfolio/driveway-after-1.png",
    stats: [
      { label: "Duration", value: "3 Days" },
      { label: "Length", value: "50 ft" },
      { label: "Type", value: "Concrete" }
    ]
  },
  {
    title: "Farm Pond Excavation",
    location: "Goshen, OH",
    category: "Excavation",
    description: "Excavated a new half-acre farm pond with shaped shelves and proper bank contours. Worked with the property owner's pond designer to hit exact depth and shape specifications.",
    before: "/images/portfolio/pond-before-1.png",
    after: "/images/portfolio/pond-after-1.png",
    stats: [
      { label: "Duration", value: "3 Days" },
      { label: "Size", value: "0.5 Acres" },
      { label: "Depth", value: "12 ft" }
    ]
  }
];
---

<Layout 
  title="Our Work | Project Gallery | Liteworks Co."
  description="See real before and after results from Liteworks Co. excavation, land clearing, drainage, and driveway projects across Greater Cincinnati."
  schema={schema}
>
  <Header client:load />

  <main class="pt-20">
    <!-- Hero -->
    <section class="bg-[#1a1a1a] py-16 md:py-24">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="flex items-center justify-center gap-2 mb-6">
          <div class="flex">
            {[1,2,3,4,5].map(() => (
              <Star className="w-5 h-5 text-yellow-400 fill-yellow-400" />
            ))}
          </div>
          <span class="text-gray-300 text-sm font-medium">5.0 from 47+ reviews</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-[Rajdhani] font-bold text-white mb-4">
          Our Work Speaks <span class="text-[#c4d931]">for Itself</span>
        </h1>
        <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-8">
          Real projects. Real results. See what Liteworks Co. can do for your property.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          {["All", "Excavation", "Land Clearing", "Drainage", "Driveways"].map((cat) => (
            <button class={`px-4 py-2 rounded font-[Rajdhani] font-semibold text-sm transition ${cat === "All" ? "bg-[#c4d931] text-[#1a1a1a]" : "bg-white/10 text-white hover:bg-white/20"}`}>
              {cat}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Projects -->
    <section class="py-16 md:py-20 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="space-y-20 max-w-6xl mx-auto">
          {projects.map((project, index) => (
            <article class={`flex flex-col ${index % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-8 lg:gap-12 items-center`}>
              
              <!-- Before/After Images -->
              <div class="w-full lg:w-3/5">
                <div class="grid grid-cols-2 gap-3">
                  <div class="relative">
                    <div class="absolute top-3 left-3 bg-red-600 text-white text-xs font-[Rajdhani] font-bold uppercase tracking-wider px-3 py-1 rounded z-10">
                      Before
                    </div>
                    <img 
                      src={project.before} 
                      alt={`${project.title} - Before`}
                      class="w-full h-64 md:h-80 object-cover rounded-lg"
                      loading="lazy"
                    />
                  </div>
                  <div class="relative">
                    <div class="absolute top-3 left-3 bg-green-600 text-white text-xs font-[Rajdhani] font-bold uppercase tracking-wider px-3 py-1 rounded z-10">
                      After
                    </div>
                    <img 
                      src={project.after} 
                      alt={`${project.title} - After`}
                      class="w-full h-64 md:h-80 object-cover rounded-lg"
                      loading="lazy"
                    />
                  </div>
                </div>
              </div>

              <!-- Project Details -->
              <div class="w-full lg:w-2/5">
                <div class="inline-block bg-[#c4d931]/20 text-[#1a1a1a] text-xs font-[Rajdhani] font-bold uppercase tracking-widest px-3 py-1 rounded mb-3">
                  {project.category}
                </div>
                <h2 class="text-2xl md:text-3xl font-[Rajdhani] font-bold text-[#1a1a1a] mb-2">
                  {project.title}
                </h2>
                <p class="text-gray-500 text-sm flex items-center gap-1 mb-4">
                  <MapPin className="w-4 h-4" />
                  {project.location}
                </p>
                <p class="text-gray-600 leading-relaxed mb-6">
                  {project.description}
                </p>
                
                <!-- Project Stats -->
                <div class="grid grid-cols-3 gap-3 mb-6">
                  {project.stats.map((stat) => (
                    <div class="bg-[#f5f5f0] rounded-lg p-3 text-center">
                      <div class="text-lg font-[Rajdhani] font-bold text-[#1a1a1a]">{stat.value}</div>
                      <div class="text-xs text-gray-500">{stat.label}</div>
                    </div>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Full Gallery -->
    <section class="py-16 md:py-20 bg-[#f5f5f0]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl md:text-4xl font-[Rajdhani] font-bold text-center text-[#1a1a1a] mb-4">
          Project Gallery
        </h2>
        <p class="text-center text-gray-500 mb-12 max-w-2xl mx-auto">
          A closer look at our work across Greater Cincinnati — excavation, grading, retaining walls, drainage, and more.
        </p>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
          {[
            { src: "/images/gallery/residential/excavation-1.png", label: "Excavation" },
            { src: "/images/gallery/residential/excavation-2.png", label: "Excavation" },
            { src: "/images/gallery/residential/excavation-3.png", label: "Excavation" },
            { src: "/images/gallery/residential/land-clearing-1.png", label: "Land Clearing" },
            { src: "/images/gallery/residential/land-clearing-2.png", label: "Land Clearing" },
            { src: "/images/gallery/residential/land-clearing-3.png", label: "Land Clearing" },
            { src: "/images/gallery/residential/grading-1.png", label: "Grading & Leveling" },
            { src: "/images/gallery/residential/grading-2.png", label: "Grading & Leveling" },
            { src: "/images/gallery/residential/grading-3.png", label: "Grading & Leveling" },
            { src: "/images/gallery/residential/retaining-walls-1.png", label: "Retaining Walls" },
            { src: "/images/gallery/residential/retaining-walls-2.png", label: "Retaining Walls" },
            { src: "/images/gallery/residential/retaining-walls-3.png", label: "Retaining Walls" },
            { src: "/images/gallery/residential/drainage-1.png", label: "Drainage" },
            { src: "/images/gallery/residential/drainage-2.png", label: "Drainage" },
            { src: "/images/gallery/residential/drainage-3.png", label: "Drainage" },
            { src: "/images/gallery/residential/demolition-1.png", label: "Demolition" },
            { src: "/images/gallery/residential/demolition-2.png", label: "Demolition" },
            { src: "/images/gallery/residential/demolition-3.png", label: "Demolition" },
            { src: "/images/gallery/residential/driveways-1.png", label: "Driveways" },
            { src: "/images/gallery/residential/driveways-2.png", label: "Driveways" },
            { src: "/images/gallery/residential/driveways-3.png", label: "Driveways" },
            { src: "/images/gallery/residential/foundation-1.png", label: "Foundation Work" },
            { src: "/images/gallery/residential/foundation-2.png", label: "Foundation Work" },
            { src: "/images/gallery/residential/foundation-3.png", label: "Foundation Work" },
            { src: "/images/gallery/residential/pool-removal-1.png", label: "Pool Removal" },
            { src: "/images/gallery/residential/pool-removal-2.png", label: "Pool Removal" },
            { src: "/images/gallery/residential/pool-removal-3.png", label: "Pool Removal" },
            { src: "/images/gallery/residential/pond-1.png", label: "Ponds" },
            { src: "/images/gallery/residential/pond-2.png", label: "Ponds" },
            { src: "/images/gallery/residential/pond-3.png", label: "Ponds" },
            { src: "/images/gallery/residential/concrete-removal-1.png", label: "Concrete Removal" },
            { src: "/images/gallery/residential/concrete-removal-2.png", label: "Concrete Removal" },
            { src: "/images/gallery/residential/concrete-removal-3.png", label: "Concrete Removal" },
            { src: "/images/gallery/residential/septic-1.png", label: "Septic Systems" },
            { src: "/images/gallery/residential/septic-2.png", label: "Septic Systems" },
            { src: "/images/gallery/residential/septic-3.png", label: "Septic Systems" },
            { src: "/images/gallery/residential/lot-prep-1.png", label: "Lot Prep" },
            { src: "/images/gallery/residential/lot-prep-2.png", label: "Lot Prep" },
            { src: "/images/gallery/residential/lot-prep-3.png", label: "Lot Prep" },
            { src: "/images/gallery/residential/stump-removal-1.png", label: "Stump Removal" },
            { src: "/images/gallery/residential/stump-removal-2.png", label: "Stump Removal" },
            { src: "/images/gallery/residential/stump-removal-3.png", label: "Stump Removal" },
            { src: "/images/gallery/residential/erosion-control-1.png", label: "Erosion Control" },
            { src: "/images/gallery/residential/erosion-control-2.png", label: "Erosion Control" },
            { src: "/images/gallery/residential/erosion-control-3.png", label: "Erosion Control" },
            { src: "/images/gallery/residential/snow-removal-1.png", label: "Snow Removal" },
            { src: "/images/gallery/residential/snow-removal-2.png", label: "Snow Removal" },
            { src: "/images/gallery/residential/snow-removal-3.png", label: "Snow Removal" },
            { src: "/images/gallery/residential/utilities-1.png", label: "Utilities" },
            { src: "/images/gallery/residential/utilities-2.png", label: "Utilities" },
            { src: "/images/gallery/residential/utilities-3.png", label: "Utilities" },
          ].map((img) => (
            <div class="group relative overflow-hidden rounded-lg aspect-[4/3]">
              <img 
                src={img.src}
                alt={img.label}
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              <div class="absolute bottom-0 left-0 right-0 p-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <span class="text-white text-sm font-[Rajdhani] font-semibold">{img.label}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="py-12 bg-[#1a1a1a]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 max-w-4xl mx-auto text-center">
          {[
            { value: "150+", label: "Projects Completed" },
            { value: "50+", label: "5-Star Reviews" },
            { value: "10+", label: "Years Experience" },
            { value: "100%", label: "Client Satisfaction" }
          ].map((stat) => (
            <div>
              <div class="text-3xl md:text-4xl font-[Rajdhani] font-bold text-[#c4d931]">{stat.value}</div>
              <div class="text-gray-400 text-sm mt-1">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 md:py-20 bg-[#c4d931]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-4xl md:text-5xl font-[Rajdhani] font-bold text-[#1a1a1a] mb-4">
          Ready for Your Transformation?
        </h2>
        <p class="text-xl text-[#1a1a1a]/80 mb-8 max-w-2xl mx-auto">
          Tell us about your project and get a free, no-obligation quote within 24 hours.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/get-a-quote" class="inline-flex items-center justify-center px-10 py-5 bg-[#1a1a1a] text-white font-[Rajdhani] font-semibold text-xl rounded hover:bg-black transition">
            Get Your Free Quote
          </a>
          <a href="tel:5139279675" class="inline-flex items-center justify-center px-10 py-5 bg-transparent border-2 border-[#1a1a1a] text-[#1a1a1a] font-[Rajdhani] font-semibold text-xl rounded hover:bg-[#1a1a1a] hover:text-white transition">
            <Phone className="w-5 h-5 mr-2" />
            (513) 927-9675
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
