---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Careers | Join the Liteworks Team | Cincinnati"
  description="Join the Liteworks Co. team. We're hiring experienced equipment operators, laborers, and CDL drivers in Greater Cincinnati. Competitive pay, growth opportunities, modern equipment."
>
  <Header client:load />

  <main class="pt-20">
    <!-- Hero -->
    <section class="relative overflow-hidden bg-[#1a1a1a]" style="height: 50vh; min-height: 340px;">
      <video
        class="absolute inset-0 w-full h-full object-cover opacity-40"
        autoplay
        muted
        loop
        playsinline
      >
        <source src="/videos/workers-by-excavator.mp4" type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-gradient-to-r from-[#1a1a1a]/90 via-[#1a1a1a]/70 to-transparent"></div>

      <div class="relative h-full flex flex-col justify-end container mx-auto px-4 sm:px-6 lg:px-8 pb-10">
        <nav class="text-sm mb-4">
          <a href="/" class="text-gray-400 hover:text-[#c4d931]">Home</a>
          <span class="text-gray-600 mx-2">/</span>
          <span class="text-[#c4d931]">Careers</span>
        </nav>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-[Rajdhani] font-bold text-white mb-4 drop-shadow-lg">
          Join the Liteworks Team
        </h1>
        <p class="text-lg text-gray-200 max-w-2xl drop-shadow">
          We're building something great in Greater Cincinnati — and we're looking for people who take pride in doing the work right.
        </p>
      </div>
    </section>

    <!-- Intro -->
    <section class="py-20 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-3xl md:text-4xl font-[Rajdhani] font-bold text-[#1a1a1a] mb-6">
            Grow With a Company That's Going Places
          </h2>
          <p class="text-lg text-gray-600 mb-6 leading-relaxed">
            Liteworks Co. is a growing excavation and sitework contractor serving Greater Cincinnati, Northern Kentucky, and Southeast Indiana. We run modern equipment, build a strong team culture, and give the right people real opportunities to advance.
          </p>
          <p class="text-lg text-gray-600 leading-relaxed">
            We're not a revolving-door employer. We invest in the people who show up, work hard, and take ownership of their craft. If that sounds like you, we want to talk.
          </p>
        </div>
      </div>
    </section>

    <!-- Open Positions -->
    <section class="py-20 bg-[#f5f5f0]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl md:text-4xl font-[Rajdhani] font-bold text-center text-[#1a1a1a] mb-4">
          Current Openings
        </h2>
        <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
          We're always looking for the right people — even if you don't see an exact match, send us your resume.
        </p>

        <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
          <!-- Position 1 -->
          <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
            <div class="w-12 h-12 bg-[#c4d931]/20 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[#c4d931]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18" />
              </svg>
            </div>
            <h3 class="text-xl font-[Rajdhani] font-bold text-[#1a1a1a] mb-2">Equipment Operator</h3>
            <p class="text-gray-500 text-sm mb-4">Full-Time · Greater Cincinnati Area</p>
            <p class="text-gray-600 text-sm leading-relaxed">
              Experienced operators for excavators, track loaders, and compact equipment. Prior excavation or sitework experience required. Willingness to run multiple machine types a plus.
            </p>
          </div>

          <!-- Position 2 -->
          <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
            <div class="w-12 h-12 bg-[#c4d931]/20 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[#c4d931]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-[Rajdhani] font-bold text-[#1a1a1a] mb-2">Laborer / Crew Member</h3>
            <p class="text-gray-500 text-sm mb-4">Full-Time · Greater Cincinnati Area</p>
            <p class="text-gray-600 text-sm leading-relaxed">
              Hard-working crew members to support site operations — drainage installation, pipe laying, erosion control, hand work, and general site labor. Construction experience helpful but not required for the right person.
            </p>
          </div>

          <!-- Position 3 -->
          <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
            <div class="w-12 h-12 bg-[#c4d931]/20 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[#c4d931]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
              </svg>
            </div>
            <h3 class="text-xl font-[Rajdhani] font-bold text-[#1a1a1a] mb-2">CDL Driver</h3>
            <p class="text-gray-500 text-sm mb-4">Full-Time · Greater Cincinnati Area</p>
            <p class="text-gray-600 text-sm leading-relaxed">
              CDL-A or CDL-B drivers for equipment transport and material hauling. Experience with lowboy trailers and dump operations preferred. Clean driving record required.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="py-20 bg-[#1a1a1a]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl md:text-4xl font-[Rajdhani] font-bold text-center text-white mb-4">
          Why Liteworks
        </h2>
        <p class="text-center text-gray-400 mb-12 max-w-2xl mx-auto">
          What you can expect when you join the team
        </p>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
          <div class="text-center">
            <div class="w-14 h-14 bg-[#c4d931]/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-[#c4d931]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-[Rajdhani] font-bold text-white mb-2">Competitive Pay</h3>
            <p class="text-gray-400 text-sm">We pay for skill and reliability — above-market wages for the right people who show up and perform.</p>
          </div>

          <div class="text-center">
            <div class="w-14 h-14 bg-[#c4d931]/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-[#c4d931]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </div>
            <h3 class="text-lg font-[Rajdhani] font-bold text-white mb-2">Growth Opportunities</h3>
            <p class="text-gray-400 text-sm">We're growing fast. Crew leads, foremen, and operations roles open up as we expand — we promote from within.</p>
          </div>

          <div class="text-center">
            <div class="w-14 h-14 bg-[#c4d931]/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-[#c4d931]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18" />
              </svg>
            </div>
            <h3 class="text-lg font-[Rajdhani] font-bold text-white mb-2">Modern Equipment</h3>
            <p class="text-gray-400 text-sm">We run well-maintained, modern machines. You'll spend your day on equipment that works the way it's supposed to.</p>
          </div>

          <div class="text-center">
            <div class="w-14 h-14 bg-[#c4d931]/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-[#c4d931]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-[Rajdhani] font-bold text-white mb-2">Team Environment</h3>
            <p class="text-gray-400 text-sm">Small company, real camaraderie. Everyone knows your name, your work matters, and the team has your back.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Apply CTA -->
    <section class="py-20 bg-[#c4d931]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-4xl md:text-5xl font-[Rajdhani] font-bold text-[#1a1a1a] mb-6">
          Ready to Apply?
        </h2>
        <p class="text-xl text-[#1a1a1a]/80 mb-4 max-w-2xl mx-auto">
          Send your resume and a brief note about your experience to:
        </p>
        <a 
          href="mailto:team@liteworksco.com?subject=Employment%20Application%20-%20Liteworks%20Co."
          class="inline-flex items-center justify-center px-8 py-4 bg-[#1a1a1a] text-white font-[Rajdhani] font-semibold text-xl rounded hover:bg-black transition mb-6"
        >
          team@liteworksco.com
        </a>
        <p class="text-[#1a1a1a]/70 text-base max-w-xl mx-auto">
          No formal application system — just send us your resume and tell us a bit about yourself. We respond to everyone who applies.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
