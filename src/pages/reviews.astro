---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer.astro';
import { Star, MessageSquare, ExternalLink } from 'lucide-react';

const reviews = [
  {
    name: "Kevin M.",
    location: "Anderson Township, OH",
    rating: 5,
    date: "November 2024",
    project: "Basement Excavation",
    text: "We brought Liteworks in to excavate for a full basement addition on the back of our house in Anderson Township. Tight access, clay soil, and a neighbor's fence about six feet from the dig — the kind of job that makes a lot of contractors nervous. These guys showed up with the right machine, took their time along the property line, and nailed it. Our GC said it was one of the cleaner excavations he'd worked with. The addition is framed now. Couldn't be happier."
  },
  {
    name: "Greg P.",
    location: "Blue Ash, OH",
    rating: 5,
    date: "September 2024",
    project: "Commercial Site Excavation",
    text: "I'm a GC and I've subbed Liteworks on two commercial projects now — most recently a new retail build off Kenwood Road. They coordinated directly with my super, hit their schedule, and the excavation came in clean to grade. No change orders, no surprises. That's all I ask for. Already have them penciled in for our next job in Mason."
  },
  {
    name: "Northstar Church — Facilities Team",
    location: "West Chester Township, OH",
    rating: 5,
    date: "August 2024",
    project: "Parking Lot Expansion",
    text: "We needed to expand our main parking lot before the fall program season and had a tight window to get it done. Liteworks handled the clearing, rough grading, and sub-base work for the new section. They worked around our weekend services without complaint and wrapped up the earthwork phase on time. Professional from start to finish. We'll be calling them again when we break ground on the new wing."
  },
  {
    name: "Rachel & Tom F.",
    location: "Milford, OH",
    rating: 5,
    date: "June 2024",
    project: "Land Clearing — New Home Build",
    text: "We bought a wooded lot in Milford and needed it cleared and rough-graded before our builder could start. The property was steep in the back with a lot of mature trees and thick underbrush — not a light job. Liteworks walked it with us, gave us a fair quote, and had a crew out within two weeks. By the time they were done, our builder actually commented on how well the site was prepped. We're framing now. Highly recommend."
  },
  {
    name: "Dana W.",
    location: "Loveland, OH",
    rating: 5,
    date: "May 2024",
    project: "Structure Demolition",
    text: "Managed a commercial property in Loveland with an old warehouse structure that needed to come down — asbestos already abated, just needed the shell demolished and the slab broken up. Liteworks gave me a clear scope, stuck to the timeline, and hauled everything off clean. The pad is ready for the next tenant's build-out. Exactly what I needed, no hassle."
  },
  {
    name: "Brian S.",
    location: "West Chester, OH",
    rating: 5,
    date: "April 2024",
    project: "Drainage — French Drain System",
    text: "We had a serious water problem in the lower corner of our backyard — standing water for days after any decent rain. I'd had two other companies tell me it would just 'always be wet back there.' Liteworks actually looked at the grade, figured out where the water was coming from, and designed a French drain system that redirected it properly. They were in and out in a day and a half, restored the lawn grade, and you'd barely know they were there. First heavy rain came through and the yard drained completely. Finally."
  }
];
---

<Layout 
  title="Reviews | Liteworks Co. | Cincinnati Excavation & Sitework"
  description="Read reviews from Liteworks Co. customers. See why Greater Cincinnati trusts us for excavation, land clearing, and sitework projects."
>
  <Header client:load />
  
  <main class="pt-20">
    <!-- Hero Section -->
    <section class="py-16 bg-[#1a1a1a]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-[Rajdhani] font-bold text-white mb-4">
          Customer <span class="text-[#c4d931]">Reviews</span>
        </h1>
        <p class="text-xl text-gray-300 max-w-2xl mx-auto">
          See what our customers are saying about working with Liteworks Co.
        </p>
      </div>
    </section>

    <!-- Overall Rating Banner -->
    <section class="py-12 bg-[#f5f5f0]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6 text-center">
          <div>
            <div class="text-6xl font-[Rajdhani] font-bold text-[#1a1a1a]">5.0</div>
            <div class="flex items-center justify-center gap-1 mt-1">
              {[1, 2, 3, 4, 5].map(() => (
                <Star className="w-5 h-5 text-[#c4d931] fill-current" />
              ))}
            </div>
            <p class="text-gray-500 text-sm mt-1">Average Rating</p>
          </div>
          <div class="hidden sm:block w-px h-16 bg-gray-300"></div>
          <div>
            <div class="text-6xl font-[Rajdhani] font-bold text-[#1a1a1a]">150+</div>
            <p class="text-gray-500 text-sm mt-1">Projects Completed</p>
          </div>
          <div class="hidden sm:block w-px h-16 bg-gray-300"></div>
          <div>
            <div class="text-6xl font-[Rajdhani] font-bold text-[#1a1a1a]">100%</div>
            <p class="text-gray-500 text-sm mt-1">Client Satisfaction</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Reviews Grid -->
    <section class="py-20 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
          {reviews.map((review) => (
            <div class="bg-[#f5f5f0] rounded-lg p-6 flex flex-col">
              <div class="flex items-center gap-1 mb-3">
                {Array.from({ length: review.rating }).map(() => (
                  <Star className="w-4 h-4 text-[#c4d931] fill-current" />
                ))}
                {Array.from({ length: 5 - review.rating }).map(() => (
                  <Star className="w-4 h-4 text-gray-300 fill-current" />
                ))}
              </div>
              <p class="text-gray-700 mb-4 flex-1">"{review.text}"</p>
              <div class="border-t border-gray-200 pt-4 mt-auto">
                <p class="font-[Rajdhani] font-bold text-[#1a1a1a]">{review.name}</p>
                <p class="text-sm text-gray-500">{review.location}</p>
                {review.date && <p class="text-xs text-gray-400 mt-0.5">{review.date}</p>}
                <span class="inline-block mt-2 text-xs bg-[#c4d931] text-[#1a1a1a] font-semibold px-2 py-0.5 rounded">{review.project}</span>
              </div>
            </div>
          ))}
        </div>

        <!-- Google CTA -->
        <div class="mt-16 max-w-2xl mx-auto text-center bg-[#1a1a1a] rounded-lg p-8">
          <div class="w-14 h-14 rounded-full bg-[#c4d931] flex items-center justify-center mx-auto mb-4">
            <MessageSquare className="w-7 h-7 text-[#1a1a1a]" />
          </div>
          <h3 class="text-2xl font-[Rajdhani] font-bold text-white mb-3">
            Worked With Us? Leave a Review!
          </h3>
          <p class="text-gray-400 mb-6">
            Your feedback helps other Greater Cincinnati homeowners find a contractor they can trust. It takes less than 2 minutes on Google.
          </p>
          <a
            href="https://g.page/r/liteworksco/review"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-8 py-4 bg-[#c4d931] text-[#1a1a1a] font-[Rajdhani] font-semibold text-lg rounded hover:bg-[#d4e941] transition"
          >
            Leave Us a Review on Google
            <ExternalLink className="w-5 h-5" />
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 bg-[#c4d931]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl md:text-4xl font-[Rajdhani] font-bold text-[#1a1a1a] mb-6">
          Ready to Experience the Liteworks Difference?
        </h2>
        <p class="text-lg text-[#1a1a1a]/80 mb-8 max-w-2xl mx-auto">
          Join our growing list of satisfied customers. Get your free quote today.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/get-a-quote" class="inline-flex items-center justify-center px-8 py-4 bg-[#1a1a1a] text-white font-[Rajdhani] font-semibold text-lg rounded hover:bg-black transition">
            Get Your Free Quote
          </a>
          <a href="tel:5139279675" class="inline-flex items-center justify-center px-8 py-4 bg-transparent border-2 border-[#1a1a1a] text-[#1a1a1a] font-[Rajdhani] font-semibold text-lg rounded hover:bg-[#1a1a1a] hover:text-white transition">
            Call (513) 927-9675
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
