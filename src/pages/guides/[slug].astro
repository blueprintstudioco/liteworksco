---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer.astro';
import fs from 'fs';
import path from 'path';

export async function getStaticPaths() {
  const dir = path.join(process.cwd(), 'src', 'content', 'programmatic', 'guides');
  if (!fs.existsSync(dir)) return [];
  return fs.readdirSync(dir).filter(f => f.endsWith('.json')).map(file => {
    const data = JSON.parse(fs.readFileSync(path.join(dir, file), 'utf8'));
    return { params: { slug: data.slug }, props: { data } };
  });
}

const { data } = Astro.props;

const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  "mainEntity": data.faqs?.map(f => ({ "@type": "Question", "name": f.question, "acceptedAnswer": { "@type": "Answer", "text": f.answer } }))
};
---

<Layout title={data.metaTitle} description={data.metaDescription}>
  <Header client:load />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <main class="pt-20">
    <section class="bg-secondary text-white py-16 md:py-24">
      <div class="container mx-auto px-6">
        <nav class="mb-6 text-sm text-white/50">
          <a href="/" class="hover:text-primary">Home</a><span class="mx-2">›</span>
          <a href="/guides" class="hover:text-primary">Guides</a><span class="mx-2">›</span>
          <span class="text-white">{data.title}</span>
        </nav>
        <h1 class="text-4xl md:text-5xl font-heading font-bold mb-6">{data.h1}</h1>
        <p class="text-xl text-white/70 max-w-3xl">{data.intro}</p>
      </div>
    </section>

    <!-- Table of Contents -->
    <section class="py-8 border-b border-secondary/10">
      <div class="container mx-auto px-6 max-w-3xl">
        <h2 class="text-lg font-heading font-bold mb-4">📋 In This Guide</h2>
        <nav class="space-y-2">
          {data.sections?.map((s, i) => (
            <a href={`#section-${i}`} class="block text-secondary/60 hover:text-primary transition-colors text-sm">{i+1}. {s.heading}</a>
          ))}
          <a href="#checklist" class="block text-secondary/60 hover:text-primary transition-colors text-sm">✅ Checklist</a>
          <a href="#costs" class="block text-secondary/60 hover:text-primary transition-colors text-sm">💰 Estimated Costs</a>
        </nav>
      </div>
    </section>

    <!-- Sections -->
    {data.sections?.map((section, i) => (
      <section id={`section-${i}`} class={`py-12 ${i % 2 === 0 ? '' : 'bg-muted'}`}>
        <div class="container mx-auto px-6 max-w-3xl">
          <h2 class="text-2xl font-heading font-bold mb-4">{section.heading}</h2>
          <div class="text-secondary/70 mb-6 whitespace-pre-line leading-relaxed">{section.content}</div>
          {section.tips?.length > 0 && (
            <div class="bg-primary/5 border border-primary/10 rounded-xl p-5">
              <h3 class="text-sm font-bold text-primary mb-3 font-heading">💡 Tips</h3>
              <ul class="space-y-2">
                {section.tips.map(tip => (
                  <li class="flex items-start gap-2 text-sm text-secondary/70"><span class="text-primary">•</span>{tip}</li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </section>
    ))}

    <!-- Checklist -->
    <section id="checklist" class="py-16 bg-secondary text-white">
      <div class="container mx-auto px-6 max-w-3xl">
        <h2 class="text-3xl font-heading font-bold mb-8">✅ Checklist</h2>
        <div class="space-y-3">
          {data.checklist?.map(item => (
            <div class="flex items-start gap-3 bg-white/5 rounded-lg p-4">
              <span class="text-primary flex-shrink-0">☐</span>
              <span class="text-white/80">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Costs -->
    <section id="costs" class="py-16">
      <div class="container mx-auto px-6 max-w-3xl">
        <h2 class="text-3xl font-heading font-bold mb-8">Estimated Costs</h2>
        <div class="grid grid-cols-3 gap-4 mb-6">
          <div class="bg-muted rounded-xl p-6 text-center">
            <div class="text-sm text-secondary/50 mb-2">Low End</div>
            <div class="text-3xl font-bold text-green-600">{data.estimatedCosts?.low}</div>
          </div>
          <div class="bg-primary/10 border border-primary/20 rounded-xl p-6 text-center">
            <div class="text-sm text-secondary/50 mb-2">Average</div>
            <div class="text-3xl font-bold text-primary">{data.estimatedCosts?.average}</div>
          </div>
          <div class="bg-muted rounded-xl p-6 text-center">
            <div class="text-sm text-secondary/50 mb-2">High End</div>
            <div class="text-3xl font-bold text-red-500">{data.estimatedCosts?.high}</div>
          </div>
        </div>
        <p class="text-sm text-secondary/60 italic">{data.estimatedCosts?.note}</p>
      </div>
    </section>

    <!-- FAQs -->
    <section class="py-16 bg-muted">
      <div class="container mx-auto px-6 max-w-3xl">
        <h2 class="text-3xl font-heading font-bold mb-10">Frequently Asked Questions</h2>
        <div class="space-y-4">
          {data.faqs?.map(faq => (
            <details class="group bg-white rounded-xl overflow-hidden border border-secondary/5">
              <summary class="flex items-center justify-between p-5 cursor-pointer hover:bg-muted/50 transition-colors">
                <span class="font-bold pr-4 font-heading">{faq.question}</span>
                <svg class="w-5 h-5 text-secondary/40 transition-transform group-open:rotate-180 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-5 pb-5 text-secondary/70">{faq.answer}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 bg-secondary text-white text-center">
      <div class="container mx-auto px-6">
        <h2 class="text-3xl font-heading font-bold mb-4">Ready to Get Started?</h2>
        <p class="text-white/60 mb-8 max-w-2xl mx-auto">Get a free quote from Cincinnati's trusted excavation experts.</p>
        <a href="/get-a-quote" class="inline-flex px-10 py-4 bg-primary text-secondary font-bold text-xl rounded-lg hover:bg-primary/90">Get a Free Quote →</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
