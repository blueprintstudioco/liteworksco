---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer.astro';
import { Phone, Mail, MapPin, Clock } from 'lucide-react';

const services = [
  "Site Preparation",
  "Excavation",
  "Grading & Earthwork",
  "Land Clearing",
  "Demolition",
  "Drainage & Erosion Control",
  "Utility Trenching",
  "Driveway & Road Building",
  "Other"
];
---

<Layout 
  title="Get a Quote | Liteworks Co. | Cincinnati Excavation & Sitework"
  description="Request a free quote for your excavation, sitework, or land clearing project. Contact Liteworks Co. for professional service in Greater Cincinnati."
>
  <Header client:load />
  
  <main class="pt-20">
    <!-- Hero Section -->
    <section class="py-16 bg-[#1a1a1a]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-[Rajdhani] font-bold text-white mb-4">
          Get a <span class="text-[#c4d931]">Free Quote</span>
        </h1>
        <p class="text-xl text-gray-300 max-w-2xl mx-auto">
          Tell us about your project and we'll get back to you within 24 hours
        </p>
      </div>
    </section>

    <!-- Form Section -->
    <section class="py-16 bg-[#f5f5f0]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-3 gap-12">
          <!-- Contact Info -->
          <div class="lg:col-span-1">
            <h2 class="text-2xl font-[Rajdhani] font-bold text-[#1a1a1a] mb-6">
              Contact Information
            </h2>
            
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-full bg-[#c4d931]/20 flex items-center justify-center flex-shrink-0">
                  <Phone className="w-5 h-5 text-[#c4d931]" />
                </div>
                <div>
                  <h3 class="font-semibold text-[#1a1a1a]">Phone</h3>
                  <a href="tel:5139279675" class="text-gray-600 hover:text-[#c4d931] transition">
                    (513) 927-9675
                  </a>
                </div>
              </div>
              
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-full bg-[#c4d931]/20 flex items-center justify-center flex-shrink-0">
                  <Mail className="w-5 h-5 text-[#c4d931]" />
                </div>
                <div>
                  <h3 class="font-semibold text-[#1a1a1a]">Email</h3>
                  <a href="mailto:team@liteworksco.com" class="text-gray-600 hover:text-[#c4d931] transition">
                    team@liteworksco.com
                  </a>
                </div>
              </div>
              
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-full bg-[#c4d931]/20 flex items-center justify-center flex-shrink-0">
                  <MapPin className="w-5 h-5 text-[#c4d931]" />
                </div>
                <div>
                  <h3 class="font-semibold text-[#1a1a1a]">Address</h3>
                  <p class="text-gray-600">
                    1481 SR 28, Suite 901<br />
                    Loveland, OH 45140
                  </p>
                </div>
              </div>
              
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-full bg-[#c4d931]/20 flex items-center justify-center flex-shrink-0">
                  <Clock className="w-5 h-5 text-[#c4d931]" />
                </div>
                <div>
                  <h3 class="font-semibold text-[#1a1a1a]">Response Time</h3>
                  <p class="text-gray-600">
                    We typically respond within 24 hours
                  </p>
                </div>
              </div>
            </div>
            
            <div class="mt-8 p-6 bg-white rounded-lg">
              <h3 class="font-[Rajdhani] font-bold text-[#1a1a1a] mb-3">Service Area</h3>
              <p class="text-gray-600 text-sm">
                We proudly serve Greater Cincinnati, including Hamilton, Butler, Warren, and Clermont counties in Ohio, as well as Northern Kentucky and Southeast Indiana.
              </p>
            </div>
          </div>
          
          <!-- Quote Form -->
          <div class="lg:col-span-2">
            <div class="bg-white rounded-lg p-8 shadow-sm">
              <h2 class="text-2xl font-[Rajdhani] font-bold text-[#1a1a1a] mb-6">
                Tell Us About Your Project
              </h2>
              
              <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-6">
                <div class="grid md:grid-cols-2 gap-6">
                  <!-- Name -->
                  <div>
                    <label for="name" class="block text-sm font-medium text-gray-700 mb-2">
                      Full Name *
                    </label>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      required
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#c4d931] focus:border-[#c4d931] outline-none transition"
                      placeholder="John Smith"
                    />
                  </div>
                  
                  <!-- Email -->
                  <div>
                    <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
                      Email Address *
                    </label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#c4d931] focus:border-[#c4d931] outline-none transition"
                      placeholder="john@example.com"
                    />
                  </div>
                </div>
                
                <div class="grid md:grid-cols-2 gap-6">
                  <!-- Phone -->
                  <div>
                    <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
                      Phone Number *
                    </label>
                    <input
                      type="tel"
                      id="phone"
                      name="phone"
                      required
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#c4d931] focus:border-[#c4d931] outline-none transition"
                      placeholder="(555) 123-4567"
                    />
                  </div>
                  
                  <!-- Service Type -->
                  <div>
                    <label for="service" class="block text-sm font-medium text-gray-700 mb-2">
                      Service Type *
                    </label>
                    <select
                      id="service"
                      name="service"
                      required
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#c4d931] focus:border-[#c4d931] outline-none transition bg-white"
                    >
                      <option value="">Select a service...</option>
                      {services.map((service) => (
                        <option value={service}>{service}</option>
                      ))}
                    </select>
                  </div>
                </div>
                
                <!-- Address -->
                <div>
                  <label for="address" class="block text-sm font-medium text-gray-700 mb-2">
                    Project Address *
                  </label>
                  <input
                    type="text"
                    id="address"
                    name="address"
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#c4d931] focus:border-[#c4d931] outline-none transition"
                    placeholder="123 Main St, Cincinnati, OH 45202"
                  />
                </div>
                
                <!-- Project Description -->
                <div>
                  <label for="description" class="block text-sm font-medium text-gray-700 mb-2">
                    Project Description *
                  </label>
                  <textarea
                    id="description"
                    name="description"
                    required
                    rows="5"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#c4d931] focus:border-[#c4d931] outline-none transition resize-none"
                    placeholder="Please describe your project, including approximate size, timeline, and any specific requirements..."
                  ></textarea>
                </div>
                
                <!-- Submit Button -->
                <div>
                  <button
                    type="submit"
                    class="w-full bg-[#c4d931] text-[#1a1a1a] px-8 py-4 rounded-lg font-[Rajdhani] font-bold text-lg hover:bg-[#b5ca2d] transition"
                  >
                    Submit Quote Request
                  </button>
                  <p class="text-sm text-gray-500 mt-3 text-center">
                    We'll review your project and get back to you within 24 hours.
                  </p>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
