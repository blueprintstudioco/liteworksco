---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer.astro';
import FAQ from '../../components/FAQ';
import { services, type ServiceData } from '../../data/services';
import { CheckCircle, ArrowRight } from 'lucide-react';

export function getStaticPaths() {
  return services.map(service => ({
    params: { slug: service.slug },
    props: { service }
  }));
}

interface Props {
  service: ServiceData;
}

const { service } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": service.title,
  "description": service.description,
  "provider": {
    "@type": "HomeAndConstructionBusiness",
    "name": "Liteworks Co.",
    "telephone": "+1-513-927-9675",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "1481 SR 28, Suite 901",
      "addressLocality": "Loveland",
      "addressRegion": "OH",
      "postalCode": "45140",
      "addressCountry": "US"
    }
  },
  "areaServed": ["Greater Cincinnati", "Northern Kentucky", "Southeast Indiana"]
};
---

<Layout 
  title={`${service.title} Services | Liteworks Co. | Cincinnati`}
  description={service.metaDescription}
  schema={schema}
>
  <Header client:load />
  
  <main class="pt-20">
    <!-- Hero Section -->
    <section class="relative py-32 bg-[#1a1a1a]">
      <div class="absolute inset-0">
        <img 
          src={service.image} 
          alt={service.title}
          class="w-full h-full object-cover opacity-30"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[#1a1a1a] via-[#1a1a1a]/80 to-transparent"></div>
      </div>
      <div class="relative container mx-auto px-4 sm:px-6 lg:px-8">
        <nav class="text-sm mb-6">
          <a href="/" class="text-gray-400 hover:text-[#c4d931]">Home</a>
          <span class="text-gray-600 mx-2">/</span>
          <a href="/#services" class="text-gray-400 hover:text-[#c4d931]">Services</a>
          <span class="text-gray-600 mx-2">/</span>
          <span class="text-[#c4d931]">{service.shortTitle}</span>
        </nav>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-[Rajdhani] font-bold text-white mb-6">
          {service.title}
        </h1>
        <p class="text-xl text-gray-300 max-w-2xl">
          {service.description}
        </p>
        <div class="mt-8">
          <a href="/get-a-quote" class="btn-primary text-lg">
            Get a Free Quote
          </a>
        </div>
      </div>
    </section>

    <!-- Full Description -->
    <section class="py-20 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto">
          <div class="prose prose-lg">
            {service.fullDescription.map((paragraph) => (
              <p class="text-gray-600 mb-6 text-lg leading-relaxed">{paragraph}</p>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- What's Included -->
    <section class="py-20 bg-[#f5f5f0]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl md:text-4xl font-[Rajdhani] font-bold text-center text-[#1a1a1a] mb-4">
          What's Included
        </h2>
        <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
          Every {service.shortTitle.toLowerCase()} project includes these services
        </p>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4 max-w-5xl mx-auto">
          {service.included.map((item) => (
            <div class="flex items-start gap-3 bg-white p-4 rounded-lg">
              <CheckCircle className="w-5 h-5 text-[#c4d931] flex-shrink-0 mt-0.5" />
              <span class="text-gray-700">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Our Process -->
    <section class="py-20 bg-[#1a1a1a]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl md:text-4xl font-[Rajdhani] font-bold text-center text-white mb-4">
          Our Process
        </h2>
        <p class="text-center text-gray-400 mb-12 max-w-2xl mx-auto">
          How we approach every {service.shortTitle.toLowerCase()} project
        </p>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-5xl mx-auto">
          {service.process.map((step, index) => (
            <div class="relative">
              <div class="text-6xl font-[Rajdhani] font-bold text-[#c4d931]/20 absolute -top-4 -left-2">
                {String(index + 1).padStart(2, '0')}
              </div>
              <div class="relative pt-8">
                <h3 class="text-xl font-[Rajdhani] font-bold text-white mb-3">{step.step}</h3>
                <p class="text-gray-400">{step.description}</p>
              </div>
              {index < service.process.length - 1 && (
                <div class="hidden lg:block absolute top-12 -right-4">
                  <ArrowRight className="w-6 h-6 text-[#c4d931]/40" />
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Mini FAQ -->
    <section class="py-20 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl md:text-4xl font-[Rajdhani] font-bold text-center text-[#1a1a1a] mb-4">
          Common Questions
        </h2>
        <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
          Frequently asked questions about our {service.shortTitle.toLowerCase()} services
        </p>
        
        <div class="max-w-3xl mx-auto">
          <FAQ items={service.faqs} client:load />
        </div>
        
        <div class="text-center mt-10">
          <a href="/faq" class="text-[#1a1a1a] font-semibold hover:text-[#c4d931] transition underline">
            View All FAQs →
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-[#c4d931]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-4xl md:text-5xl font-[Rajdhani] font-bold text-[#1a1a1a] mb-6">
          Ready to Get Started?
        </h2>
        <p class="text-xl text-[#1a1a1a]/80 mb-8 max-w-2xl mx-auto">
          Let's discuss your {service.shortTitle.toLowerCase()} project. Get a free quote today.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/get-a-quote" class="inline-flex items-center justify-center px-8 py-4 bg-[#1a1a1a] text-white font-[Rajdhani] font-semibold text-lg rounded hover:bg-black transition">
            Get Your Free Quote
          </a>
          <a href="tel:5139279675" class="inline-flex items-center justify-center px-8 py-4 bg-transparent border-2 border-[#1a1a1a] text-[#1a1a1a] font-[Rajdhani] font-semibold text-lg rounded hover:bg-[#1a1a1a] hover:text-white transition">
            Call (513) 927-9675
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
