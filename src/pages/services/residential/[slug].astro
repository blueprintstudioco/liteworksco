---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header';
import Footer from '../../../components/Footer.astro';
import FAQ from '../../../components/FAQ';
import { residentialServices, type ServiceData } from '../../../data/services';
import { CheckCircle, ArrowRight, Star, Shield, Clock, Award, Phone, MapPin } from 'lucide-react';
import SituationIcon from '../../../components/icons/SituationIcon';
import AnimateOnScroll from '../../../components/AnimateOnScroll';

export function getStaticPaths() {
  return residentialServices.map(service => ({
    params: { slug: service.slug },
    props: { service }
  }));
}

interface Props {
  service: ServiceData;
}

const { service } = Astro.props;

const calculatorMap: Record<string, string> = {
  'stump-removal': '/pricing/stump-removal-calculator',
  'concrete-removal': '/pricing/concrete-removal-calculator',
  'driveways': '/pricing/driveway-calculator',
  'pool-removal': '/pricing/pool-removal-calculator',
  'grading': '/pricing/grading-calculator',
  'retaining-walls': '/pricing/retaining-wall-calculator',
};
const calculatorUrl = calculatorMap[service.slug];

const residentialEnhancements: Record<string, { sharpAngle: string; costlyMistake: string; finishLine: string; homeownerWin: string }> = {
  excavation: {
    sharpAngle: "A clean dig is the difference between a smooth build and weeks of expensive rework.",
    costlyMistake: "Overdigging, bad spoil placement, and sloppy access planning can make the foundation, pool, or pond crew fight the site before they even start.",
    finishLine: "A precise hole, protected access, and a clean handoff to the next contractor.",
    homeownerWin: "You know where the dirt goes, how long the job takes, and what the next crew is getting."
  },
  "land-clearing": {
    sharpAngle: "Clearing should make the property more usable, not leave you with piles, ruts, and regret.",
    costlyMistake: "Cheap clearing usually means cut brush, debris piles, damaged keeper trees, and a property that still needs a second cleanup pass.",
    finishLine: "Open, walkable ground with brush processed, boundaries respected, and the good trees still standing.",
    homeownerWin: "You get your property back without turning it into a construction dump."
  },
  demolition: {
    sharpAngle: "Demo is not just knocking something down. The value is in making it disappear cleanly.",
    costlyMistake: "Low-bid demo often leaves concrete chunks, nails, bad grade, disposal surprises, or utility issues for you to clean up later.",
    finishLine: "The structure, concrete, or pool is gone, debris is hauled, and the site is usable again.",
    homeownerWin: "One crew handles teardown, hauling, cleanup, and final grade."
  },
  drainage: {
    sharpAngle: "Water problems do not get solved by guessing where to bury pipe.",
    costlyMistake: "A French drain without a real outlet, wrong slope, or no grade correction just moves the wet spot somewhere else.",
    finishLine: "Water has a path away from the house, out of the yard, and toward a legal outlet.",
    homeownerWin: "You understand the source of the water before anyone starts digging."
  },
  utilities: {
    sharpAngle: "Underground utility work needs clean trenching, correct depth, and careful backfill.",
    costlyMistake: "Shallow lines, poor compaction, missed locates, or bad coordination with plumbers and electricians can create expensive failures later.",
    finishLine: "A safe trench ready for the licensed utility contractor, then properly backfilled and restored.",
    homeownerWin: "The job is coordinated, marked, dug, and closed without chaos in your yard."
  },
  driveways: {
    sharpAngle: "A driveway fails from the bottom up, not the top down.",
    costlyMistake: "Thin gravel over weak soil, no crown, no culverts, and poor drainage turn a new driveway into ruts and mud fast.",
    finishLine: "A compacted base, shaped surface, and drainage that sheds water instead of holding it.",
    homeownerWin: "You get access that works in rain, freeze-thaw, delivery traffic, and everyday use."
  },
  grading: {
    sharpAngle: "The right grade makes the whole property work better.",
    costlyMistake: "Pretty dirt work that ignores runoff can send water toward the house, create soggy spots, or ruin the next phase of work.",
    finishLine: "A shaped surface that drains, supports the final use, and is ready for lawn, gravel, concrete, or construction.",
    homeownerWin: "You get usable ground instead of a yard that fights every rainstorm."
  },
  "retaining-walls": {
    sharpAngle: "A retaining wall is a drainage system with a face on it.",
    costlyMistake: "Walls fail when contractors skip base prep, geogrid, backfill stone, and water relief behind the wall.",
    finishLine: "A wall that holds grade, manages water, and creates usable space without leaning in three years.",
    homeownerWin: "You get the structure behind the wall, not just blocks stacked in a line."
  },
  "pool-removal": {
    sharpAngle: "Removing a pool is really a drainage, backfill, and compaction job.",
    costlyMistake: "Bad pool fill can settle, hold water, or create a dangerous soft spot where the pool used to be.",
    finishLine: "Pool gone, debris handled, fill placed properly, and the yard shaped for its next use.",
    homeownerWin: "You reclaim the space without inheriting a sinking backyard."
  },
  pond: {
    sharpAngle: "A good pond starts with the right shape, depth, outlet, and soil plan.",
    costlyMistake: "Digging a hole without thinking about clay, slopes, spillways, or runoff creates a muddy basin instead of a pond.",
    finishLine: "A pond excavation shaped for water, maintenance, and the property around it.",
    homeownerWin: "You know what the pond will do before the machine starts digging."
  },
  "concrete-removal": {
    sharpAngle: "Concrete removal should leave you ready for the next surface, not stuck with a busted-up mess.",
    costlyMistake: "Leaving base issues, bad grade, rebar, or chunks behind makes the replacement driveway, patio, or slab harder and more expensive.",
    finishLine: "Concrete broken, loaded, hauled, and the area cleaned up for what comes next.",
    homeownerWin: "You are not renting a dumpster, fighting rubble, or wondering what is under the slab."
  },
  septic: {
    sharpAngle: "Septic excavation has to respect slope, code, access, and soil conditions.",
    costlyMistake: "Wrong trench depth, poor coordination, or careless backfill can create inspection issues and future system problems.",
    finishLine: "Clean excavation support for the septic contractor, with safe access and proper restoration.",
    homeownerWin: "The dirt work helps the system pass and perform, instead of becoming the bottleneck."
  },
  foundation: {
    sharpAngle: "Foundation work rewards precision and punishes shortcuts.",
    costlyMistake: "Bad depth, bad drainage, or unstable subgrade causes headaches for footers, walls, waterproofing, and backfill.",
    finishLine: "A foundation area excavated, shaped, and prepared for the structure going on it.",
    homeownerWin: "The most important part of the project starts on solid ground."
  },
  "lot-prep": {
    sharpAngle: "A buildable lot is planned, cleared, graded, and accessible before the real work begins.",
    costlyMistake: "Clearing without staging, access, drainage, or debris planning slows every contractor after us.",
    finishLine: "A clean, accessible lot ready for builders, deliveries, and the next phase.",
    homeownerWin: "Your project starts organized instead of stuck in mud and brush."
  },
  "snow-removal": {
    sharpAngle: "Snow removal is about keeping access open without damaging the property underneath.",
    costlyMistake: "Poor plow planning damages gravel, landscaping, curbs, and drainage features that cost money in spring.",
    finishLine: "Clear, usable access with snow pushed where it belongs.",
    homeownerWin: "Your drive, access road, or site stays functional when weather hits."
  },
  "stump-removal": {
    sharpAngle: "A stump is not gone until the roots, grade, and cleanup are handled.",
    costlyMistake: "Grinding too shallow or leaving chips and voids creates settlement, mower hazards, and another cleanup project.",
    finishLine: "The stump is ground, chips handled, and the area ready for lawn, gravel, or landscaping.",
    homeownerWin: "You get the space back without a leftover crater."
  },
  "erosion-control": {
    sharpAngle: "Erosion control has to slow water down before it steals your yard.",
    costlyMistake: "Throwing rock at the symptom without fixing flow path, slope, or outlet usually fails after the next hard rain.",
    finishLine: "Water moves through a controlled path that protects soil, slopes, and structures.",
    homeownerWin: "You stop losing ground every time it storms."
  }
};

const residentialEnhancement = residentialEnhancements[service.slug] || {
  sharpAngle: `Good ${service.shortTitle.toLowerCase()} work is about the final result, not just running equipment.`,
  costlyMistake: "The cheap version usually skips access, drainage, cleanup, and the details that decide whether the project holds up.",
  finishLine: `A clean ${service.shortTitle.toLowerCase()} project with the site ready for whatever comes next.`,
  homeownerWin: "You get a clear plan, careful work, and fewer surprises."
};

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": service.title,
  "description": service.description,
  "provider": {
    "@type": "HomeAndConstructionBusiness",
    "name": "Liteworks Co.",
    "telephone": "+1-513-927-9675",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "1481 SR 28, Suite 901",
      "addressLocality": "Loveland",
      "addressRegion": "OH",
      "postalCode": "45140",
      "addressCountry": "US"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "50"
    }
  },
  "areaServed": ["Greater Cincinnati", "Northern Kentucky", "Southeast Indiana"]
};

const hasSituations = service.situations && service.situations.length > 0;
const hasGallery = service.galleryImages && service.galleryImages.length > 0;
const hasExpectations = service.expectations;
const hasTestimonial = service.testimonial;
const isExcavation = service.slug === 'excavation';

const excavationProjectTypes = [
  {
    title: 'Foundation digs',
    copy: 'Builder-ready excavation for new homes, additions, crawlspaces, and basement walls where depth and dimensions matter.',
    image: '/images/gallery/residential/foundation-1.png',
    stat: 'Exact depth'
  },
  {
    title: 'Pool excavation',
    copy: 'Clean access, spec-driven digging, and spoil planning so the pool crew is not fighting a rough hole.',
    image: '/images/gallery/residential/excavation-1.png',
    stat: 'Clean handoff'
  },
  {
    title: 'Ponds & acreage',
    copy: 'Shape, shelf, slope, and overflow planning for rural properties that need more than a hole in the ground.',
    image: '/images/gallery/residential/pond-2.png',
    stat: 'Water planned'
  },
  {
    title: 'Tight-access yard work',
    copy: 'Right-sized equipment, matting when needed, and a plan for protecting lawn, gates, drives, and neighbors.',
    image: '/images/residential/excavation.png',
    stat: 'Yard protected'
  }
];

const excavationQuoteFactors = [
  'Access width and equipment path',
  'Dig depth, dimensions, and plan requirements',
  'Clay, rock, moisture, and soil stability',
  'Where excavated material goes',
  'Utility locates and keep-out zones',
  'Final grade and next-contractor handoff'
];
---

<Layout 
  title={`${service.title} | Liteworks Co. | Cincinnati`}
  description={service.metaDescription}
  schema={schema}
>
  <Header client:load />
  
  <main class="pt-20">
    <!-- ═══════════ HERO ═══════════ -->
    <section class="relative overflow-hidden bg-[#111111]" style="height: 56vh; min-height: 430px;">
      {service.heroVideo ? (
        <video
          class="absolute inset-0 w-full h-full object-cover"
          autoplay muted loop playsinline
        >
          <source src={service.heroVideo} type="video/mp4" />
        </video>
      ) : (
        <img 
          src={service.image} 
          alt={service.title}
          class="absolute inset-0 w-full h-full object-cover"
        />
      )}
      <div class="absolute inset-0 bg-black/65"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_72%_38%,rgba(196,217,49,0.20),transparent_28%),linear-gradient(90deg,#111111_0%,rgba(17,17,17,0.88)_42%,rgba(17,17,17,0.38)_100%)]"></div>
      <div class="absolute inset-0 liteworks-grid opacity-25"></div>

      <div class="relative h-full flex flex-col justify-end container mx-auto px-4 sm:px-6 lg:px-8 pb-10">
        <!-- Trust badges -->
        <div class="flex items-center gap-2 mb-4">
          <div class="flex">
            {[1,2,3,4,5].map(() => (
              <Star className="w-4 h-4 text-yellow-400 fill-yellow-400" />
            ))}
          </div>
          <span class="text-white text-sm font-medium">5.0 from 50+ reviews</span>
        </div>

        <div class="inline-block bg-white/20 text-white text-xs font-[Rajdhani] font-bold uppercase uppercase tracking-widest px-3 py-1 rounded mb-3 backdrop-blur-sm w-fit">
          Residential
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-[Rajdhani] font-bold uppercase text-white mb-4 drop-shadow-lg">
          {service.title}
        </h1>
        <p class="kicker mb-3">{residentialEnhancement.sharpAngle}</p>
        <p class="text-lg md:text-xl text-gray-200 max-w-3xl drop-shadow leading-relaxed">
          {service.description}
        </p>
        
        <div class="flex flex-wrap gap-3 mt-4 mb-6">
          <div class="flex items-center gap-1.5 bg-white/10 backdrop-blur-sm px-3 py-1.5 rounded text-sm">
            <Shield className="w-3.5 h-3.5 text-[#c4d931]" />
            <span class="text-white">Licensed & Insured</span>
          </div>
          <div class="flex items-center gap-1.5 bg-white/10 backdrop-blur-sm px-3 py-1.5 rounded text-sm">
            <Clock className="w-3.5 h-3.5 text-[#c4d931]" />
            <span class="text-white">Same-Week Scheduling</span>
          </div>
          <div class="flex items-center gap-1.5 bg-white/10 backdrop-blur-sm px-3 py-1.5 rounded text-sm">
            <Award className="w-3.5 h-3.5 text-[#c4d931]" />
            <span class="text-white">Free Quotes</span>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/get-a-quote" class="btn-primary text-base">
            Get a Free Quote →
          </a>
          <a href="tel:5139279675" class="btn-secondary text-base">
            <Phone className="w-4 h-4 mr-2" />
            (513) 927-9675
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════ PRICING CALCULATOR BANNER ═══════════ -->
    {calculatorUrl && (
      <section class="bg-[#c4d931] py-4">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <a href={calculatorUrl} class="flex items-center justify-center gap-3 text-[#1a1a1a] hover:opacity-80 transition">
            <span class="text-lg">📐</span>
            <span class="font-[Rajdhani] font-bold uppercase text-lg">How much does {service.shortTitle.toLowerCase()} cost?</span>
            <span class="font-semibold">Try our free pricing calculator →</span>
          </a>
        </div>
      </section>
    )}

    <!-- ═══════════ STRONG CONVERSION POSITIONING ═══════════ -->
    <section class="bg-[#111111] text-white py-16 md:py-20 liteworks-topo border-y border-white/10">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-[0.85fr_1.15fr] gap-10 items-stretch">
          <div class="border border-[#c4d931]/40 bg-[#c4d931] text-[#111111] p-8 md:p-10 flex flex-col justify-between">
            <div>
              <p class="text-sm uppercase tracking-[0.25em] font-bold mb-4">The Liteworks standard</p>
              <h2 class="text-4xl md:text-5xl font-[Rajdhani] font-bold uppercase leading-none mb-5">
                Not just dirt work. Outcome work.
              </h2>
              <p class="text-lg text-[#111111]/80 leading-relaxed">
                {residentialEnhancement.homeownerWin}
              </p>
            </div>
            <a href="/get-a-quote" class="mt-8 inline-flex justify-center bg-[#111111] text-white px-6 py-4 font-[Rajdhani] font-bold uppercase tracking-wide hover:bg-black transition">
              Get a Site Visit
            </a>
          </div>

          <div class="grid md:grid-cols-2 gap-4">
            <div class="card-dark p-7">
              <p class="kicker mb-3">What goes wrong</p>
              <h3 class="text-2xl font-[Rajdhani] font-bold uppercase text-white mb-4">Cheap work gets expensive fast</h3>
              <p class="text-gray-300 leading-relaxed">{residentialEnhancement.costlyMistake}</p>
            </div>
            <div class="card-dark p-7">
              <p class="kicker mb-3">What we leave behind</p>
              <h3 class="text-2xl font-[Rajdhani] font-bold uppercase text-white mb-4">A site that is actually ready</h3>
              <p class="text-gray-300 leading-relaxed">{residentialEnhancement.finishLine}</p>
            </div>
            <div class="md:col-span-2 grid sm:grid-cols-3 gap-4">
              <div class="border border-white/10 bg-white/5 p-5">
                <div class="text-3xl font-[Rajdhani] font-bold text-[#c4d931] mb-1">01</div>
                <p class="font-semibold">Walk the site and find the constraint.</p>
              </div>
              <div class="border border-white/10 bg-white/5 p-5">
                <div class="text-3xl font-[Rajdhani] font-bold text-[#c4d931] mb-1">02</div>
                <p class="font-semibold">Plan access, water, spoil, and cleanup.</p>
              </div>
              <div class="border border-white/10 bg-white/5 p-5">
                <div class="text-3xl font-[Rajdhani] font-bold text-[#c4d931] mb-1">03</div>
                <p class="font-semibold">Do the work and leave it ready.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════ EXCAVATION FLAGSHIP SECTION ═══════════ -->
    {isExcavation && (
      <>
        <section class="py-18 md:py-24 bg-white overflow-hidden">
          <div class="container mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid lg:grid-cols-[0.9fr_1.1fr] gap-10 items-end mb-12">
              <div>
                <p class="kicker mb-3">Residential excavation paths</p>
                <h2 class="text-4xl md:text-6xl font-[Rajdhani] font-bold uppercase text-[#111111] leading-none">
                  Different dig. Same standard.
                </h2>
              </div>
              <p class="text-lg text-gray-600 leading-relaxed max-w-2xl">
                A pool dig, foundation dig, and pond dig all fail in different ways. We separate the work by outcome because homeowners are not buying “excavation.” They are buying the next phase going smoothly.
              </p>
            </div>

            <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-5">
              {excavationProjectTypes.map((item) => (
                <article class="group relative min-h-[410px] overflow-hidden bg-[#111111] border border-black/10 shadow-2xl">
                  <img src={item.image} alt={item.title} class="absolute inset-0 w-full h-full object-cover opacity-70 group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                  <div class="absolute inset-0 bg-gradient-to-t from-[#111111] via-[#111111]/52 to-transparent"></div>
                  <div class="absolute top-4 left-4 bg-[#c4d931] text-[#111111] px-3 py-2 font-[Rajdhani] font-bold uppercase tracking-wide text-sm">
                    {item.stat}
                  </div>
                  <div class="relative z-10 h-full flex flex-col justify-end p-6">
                    <h3 class="text-3xl font-[Rajdhani] font-bold uppercase text-white mb-3">{item.title}</h3>
                    <p class="text-gray-200 leading-relaxed">{item.copy}</p>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="py-18 md:py-24 bg-[#111111] text-white liteworks-grid overflow-hidden">
          <div class="container mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid lg:grid-cols-2 gap-12 items-center">
              <div>
                <p class="kicker mb-3">The part homeowners do not see</p>
                <h2 class="text-4xl md:text-6xl font-[Rajdhani] font-bold uppercase leading-none mb-6">
                  The dig is easy. The plan is where the money is.
                </h2>
                <p class="text-xl text-gray-300 leading-relaxed mb-8">
                  Before a machine touches the yard, Liteworks is thinking through access, underground utilities, spoil placement, drainage, and how the site gets handed off. That is what keeps a one-day dig from becoming a two-week mess.
                </p>
                <div class="grid sm:grid-cols-2 gap-3">
                  {excavationQuoteFactors.map((factor) => (
                    <div class="flex items-start gap-3 border border-white/10 bg-white/5 p-4">
                      <CheckCircle className="w-5 h-5 text-[#c4d931] flex-shrink-0 mt-0.5" />
                      <span class="text-gray-200 font-medium">{factor}</span>
                    </div>
                  ))}
                </div>
              </div>
              <div class="relative">
                <div class="absolute -inset-6 bg-[#c4d931]/20 blur-3xl"></div>
                <img src="/images/residential/excavation-site-plan.svg" alt="Excavation planning diagram showing access, utility locate, excavation zone, drainage path, and spoil area" class="relative w-full border border-[#c4d931]/40 shadow-2xl" loading="lazy" />
              </div>
            </div>
          </div>
        </section>

        <section class="py-16 md:py-20 bg-[#f5f5f0]">
          <div class="container mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid lg:grid-cols-[1fr_0.8fr] gap-10 items-center">
              <div>
                <p class="kicker mb-3">Before we quote it</p>
                <h2 class="text-4xl md:text-5xl font-[Rajdhani] font-bold uppercase text-[#111111] leading-none mb-6">
                  Send plans if you have them. If not, we will walk it.
                </h2>
                <p class="text-lg text-gray-700 leading-relaxed mb-6">
                  The best excavation quote comes from knowing the constraints. For a foundation or pool, plans help. For a pond, tight backyard, or acreage project, the site visit matters more. Either way, the goal is a clear scope before equipment shows up.
                </p>
                <div class="flex flex-col sm:flex-row gap-3">
                  <a href="/get-a-quote" class="btn-primary">Start My Excavation Quote →</a>
                  <a href="tel:5139279675" class="btn-secondary">Call (513) 927-9675</a>
                </div>
              </div>
              <div class="bg-[#111111] p-7 shadow-2xl">
                <h3 class="text-2xl font-[Rajdhani] font-bold uppercase text-white mb-5">Good quote inputs</h3>
                <ul class="space-y-4">
                  {['Address and access photos', 'Plans, pool dig sheet, or rough dimensions', 'Where dirt can stay or whether it needs hauled', 'Any known utilities, septic, or drainage issues', 'Timeline for builders, pool crews, or concrete crews'].map((item) => (
                    <li class="flex items-start gap-3 text-gray-200">
                      <span class="text-[#c4d931] font-bold">✓</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </section>
      </>
    )}

    <!-- ═══════════ COMMON SITUATIONS — "Is this right for you?" ═══════════ -->
    {hasSituations ? (
      <section class="py-16 md:py-20 bg-[#f5f5f0] liteworks-grid-dark">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-3xl md:text-5xl font-[Rajdhani] font-bold uppercase text-center text-[#1a1a1a] mb-4">
            Sound Like Your Situation?
          </h2>
          <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
            Here are some common reasons Cincinnati homeowners call us for {service.shortTitle.toLowerCase()}
          </p>

          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
            {service.situations!.map((situation, i) => (
              <AnimateOnScroll client:visible delay={i * 0.1}>
                <div class="bg-white rounded-sm border border-black/10 p-7 h-full shadow-xl hover:-translate-y-1 hover:shadow-2xl transition-all">
                  <div class="w-14 h-14 bg-[#111111] flex items-center justify-center mb-4">
                    <SituationIcon client:visible icon={situation.icon} size={30} className="text-[#c4d931]" />
                  </div>
                  <h3 class="font-[Rajdhani] font-bold uppercase text-xl text-[#1a1a1a] mb-3">{situation.title}</h3>
                  <p class="text-gray-600 text-sm leading-relaxed">{situation.description}</p>
                </div>
              </AnimateOnScroll>
            ))}
          </div>

          <div class="text-center mt-10">
            <a href="/get-a-quote" class="btn-primary text-base">
              Get a Free Quote →
            </a>
          </div>
        </div>
      </section>
    ) : (
      <!-- Fallback: use fullDescription if no situations defined yet -->
      <section class="py-16 md:py-20 bg-white">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <div class="max-w-3xl mx-auto">
